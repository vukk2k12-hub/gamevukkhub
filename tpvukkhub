-- Utility: trim
local function trim(s)
	return (s:gsub("^%s*(.-)%s*$", "%1"))
end

-- Parse coordinate input string into Vector3.
-- Supported patterns:
-- - "x,y,z" (3 parts). Use "~" to keep current axis.
-- - "x,y" (2 parts) interpreted as x,y,z=current
-- - "y" (1 part) interpreted as set Y only (X,Z current)
-- - If a part is empty or "~" => keep current axis
-- Returns Vector3 or nil on failure.
local function parseCoordString(str)
	local char = player.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
	local hrp = char.HumanoidRootPart
	local cur = hrp.Position

	if not str or str == "" then return nil end

	local parts = {}
	for p in string.gmatch(str, "[^,]+") do
		table.insert(parts, trim(p))
	end

	-- Handle empty parts if input contains consecutive commas (split preserved above doesn't capture empty).
	-- So reconstruct splitting that preserves empties:
	local function splitPreserveEmpty(s)
		local t = {}
		local field = ""
		for i = 1, #s do
			local c = s:sub(i,i)
			if c == "," then
				table.insert(t, trim(field))
				field = ""
			else
				field = field .. c
			end
		end
		table.insert(t, trim(field))
		return t
	end

	parts = splitPreserveEmpty(str)

	local px,py,pz = cur.X, cur.Y, cur.Z

	if #parts == 1 then
		local p = parts[1]
		if p == "~" or p == "" then
			-- nothing specified -> current position
			return cur
		end
		local n = tonumber(p)
		if n then
			-- interpret single number as Y (set height), keep X/Z
			py = n
			return Vector3.new(px, py, pz)
		else
			return nil
		end
	elseif #parts == 2 then
		-- interpret as x,y with z=current
		local vals = {parts[1], parts[2], "~"}
		parts = vals
	end

	-- now expect at least 3 parts; if more, take first 3
	if #parts >= 3 then
		local function parsePart(part, current)
			if part == nil or part == "" or part == "~" then
				return current
			end
			local n = tonumber(part)
			if n then return n end
			-- if parsing fails, return nil to indicate error
			return nil
		end

		local a = parsePart(parts[1], px)
		local b = parsePart(parts[2], py)
		local c = parsePart(parts[3], pz)

		if a == nil or b == nil or c == nil then
			return nil
		end

		return Vector3.new(a,b,c)
	end

	return nil
end

