local function CreateConfigSlot(defaultName)

	local Row = Instance.new("Frame")
	Row.Size = UDim2.new(1,0,0,40)
	Row.BackgroundTransparency = 1
	Row.Parent = ConfigList

	local Lay = Instance.new("UIListLayout")
	Lay.FillDirection = Enum.FillDirection.Horizontal
	Lay.Padding = UDim.new(0,5)
	Lay.Parent = Row

	local Name = Instance.new("TextBox")
	Name.Size = UDim2.new(0,80,0,35)
	Name.Text = defaultName or ""
	Name.PlaceholderText = "Name"
	Name.BackgroundColor3 = Color3.fromRGB(255,255,255)
	Name.Parent = Row
	Instance.new("UICorner",Name)

	local Save = Instance.new("TextButton")
	Save.Size = UDim2.new(0,40,0,35)
	Save.Text = "Save"
	Save.Parent = Row
	Save.BackgroundColor3 = Color3.fromRGB(255,255,255)
	Instance.new("UICorner",Save)

	local Load = Instance.new("TextButton")
	Load.Size = UDim2.new(0,40,0,35)
	Load.Text = "Load"
	Load.Parent = Row
	Load.BackgroundColor3 = Color3.fromRGB(255,255,255)
	Instance.new("UICorner",Load)

	local Delete = Instance.new("TextButton")
	Delete.Size = UDim2.new(0,50,0,35)
	Delete.Text = "Delete"
	Delete.Parent = Row
	Delete.BackgroundColor3 = Color3.fromRGB(255,255,255)
	Instance.new("UICorner",Delete)

	Save.MouseButton1Click:Connect(function()
		if Name.Text == "" then return end

		local all = ReadData()
		all[Name.Text] = GetTPSlots()
		SaveData(all)
	end)

	Load.MouseButton1Click:Connect(function()
		local all = ReadData()

		if all[Name.Text] then
			LoadTPSlots(all[Name.Text])
		end
	end)

	Delete.MouseButton1Click:Connect(function()
		local all = ReadData()
		all[Name.Text] = nil
		SaveData(all)

		Row:Destroy()
	end)

end

