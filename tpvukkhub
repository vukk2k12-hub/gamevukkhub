-- Teleport mode globals
-- modes: "instant", "smooth", "step"
local tpMode = "instant"
local stepDistance = 10 -- default step distance in studs
local smoothSpeed = 80 -- studs per second for smooth mode (adjustable)

local function teleport(pos)
	local char=player.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then return end
	local hrp=char.HumanoidRootPart

	-- vehicle teleport
	if tpVehicle then
		for _,v in pairs(workspace:GetDescendants()) do
			if (v:IsA("Seat") or v:IsA("VehicleSeat")) and v.Occupant==char:FindFirstChildOfClass("Humanoid") then
				v.CFrame=CFrame.new(pos)
				return
			end
		end
	end

	-- Teleport depending on mode
	if tpMode == "instant" then
		hrp.CFrame=CFrame.new(pos)
		return
	elseif tpMode == "smooth" then
		-- compute distance and duration from smoothSpeed
		local dist = (hrp.Position - pos).Magnitude
		local duration = 0
		if smoothSpeed > 0 then
			duration = math.clamp(dist / smoothSpeed, 0.05, 10)
		else
			duration = 0.5
		end
		local tween = TweenService:Create(hrp, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = CFrame.new(pos)})
		tween:Play()
		return
	elseif tpMode == "step" then
		-- move in increments of stepDistance until reach within stepDistance of target
		task.spawn(function()
			local target = pos
			while true do
				if not char or not char.Parent or not hrp.Parent then break end
				local curPos = hrp.Position
				local dir = (target - curPos)
				local dist = dir.Magnitude
				if dist <= 1 then
					hrp.CFrame = CFrame.new(target)
					break
				end
				local step = math.min(stepDistance, dist)
				local nextPos = curPos + dir.Unit * step
				hrp.CFrame = CFrame.new(nextPos)
				wait(0.08) -- short pause between steps; adjust for smoothness
			end
		end)
		return
	end
end

