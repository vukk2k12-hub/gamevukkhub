-- Save pointer to old createSlot (we defined earlier)
local oldCreateSlot = createSlot

createSlot = function(loadData)

	oldCreateSlot()

	local row

	for _,v in pairs(List:GetChildren()) do
		if v:IsA("Frame") then
			row = v
		end
	end

	if not row then return end

	-- SavedPos
	if not row:FindFirstChild("SavedPos") then
		local val = Instance.new("Vector3Value")
		val.Name = "SavedPos"
		val.Parent = row
	end

	-- save button lưu vị trí (bind again in case)
	for _,obj in pairs(row:GetChildren()) do
		if obj:IsA("TextButton") and obj.Text == "Save" then
			-- disconnect previous connections not trivial; we just add another handler
			obj.MouseButton1Click:Connect(function()
				local char = player.Character
				if char and char:FindFirstChild("HumanoidRootPart") then
					row.SavedPos.Value = char.HumanoidRootPart.Position
				end
			end)
		end
	end

	-- bind TP button to use current teleport function (if SavedPos present)
	for _,obj in pairs(row:GetChildren()) do
		if obj:IsA("TextButton") and obj.Text == "TP" then
			obj.MouseButton1Click:Connect(function()
				if row:FindFirstChild("SavedPos") and row.SavedPos.Value then
					teleport(row.SavedPos.Value)
				end
			end)
		end
	end

	-- load data config into UI
	if loadData then

		local pos = nil

		for _,obj in pairs(row:GetChildren()) do
			if obj:IsA("TextBox") then
				obj.Text = loadData.name or ""
				break
			end
		end

		if loadData.pos then
			pos = Vector3.new(
				loadData.pos.x,
				loadData.pos.y,
				loadData.pos.z
			)

			row.SavedPos.Value = pos
		end

		-- Bind TP button (already bound above) -- kept for redundancy
		if pos then
			for _,obj in pairs(row:GetChildren()) do
				if obj:IsA("TextButton") and obj.Text == "TP" then
					obj.MouseButton1Click:Connect(function()
						teleport(pos)
					end)
				end
			end
		end
	end
end

