-- Modified makeTab to accept index param (0..n-1)
local function makeTab(text, index, total)
	local total = total or 2
	local sizeX = 1/total
	local b = Instance.new("TextButton")
	b.Size = UDim2.new(sizeX, -6, 0, 30)
	b.Position = UDim2.new(sizeX * index, index == 0 and 5 or 0, 0, 2)
	-- adjust x offset for edges
	if index == total-1 then
		-- push left offset a little for last tab
		b.Position = UDim2.new(sizeX * index, -5, 0, 2)
	end
	b.BackgroundColor3=Color3.fromRGB(255,255,255)
	b.TextColor3=Color3.new(0,0,0)
	b.Text=text
	b.Parent=TabBar
	Instance.new("UICorner",b)
	return b
end

