local oldCreateSlot = createSlot

createSlot = function(loadData)

	oldCreateSlot()

	local row

	for _,v in pairs(List:GetChildren()) do
		if v:IsA("Frame") then
			row = v
		end
	end

	if not row then return end

	-- SavedPos
	if not row:FindFirstChild("SavedPos") then
		local val = Instance.new("Vector3Value")
		val.Name = "SavedPos"
		val.Parent = row
	end

	-- save button lưu vị trí
	for _,obj in pairs(row:GetChildren()) do
		if obj:IsA("TextButton") and obj.Text == "Save" then
			obj.MouseButton1Click:Connect(function()
				local char = player.Character
				if char and char:FindFirstChild("HumanoidRootPart") then
					row.SavedPos.Value =
						char.HumanoidRootPart.Position
				end
			end)
		end
	end

	-- load data config
	if loadData then

		local pos = nil

		for _,obj in pairs(row:GetChildren()) do
			if obj:IsA("TextBox") then
				obj.Text = loadData.name or ""
				break
			end
		end

		if loadData.pos then
			pos = Vector3.new(
				loadData.pos.x,
				loadData.pos.y,
				loadData.pos.z
			)

			row.SavedPos.Value = pos
		end

		-- bind lại nút TP
		if pos then
			for _,obj in pairs(row:GetChildren()) do
				if obj:IsA("TextButton") and obj.Text == "TP" then
					obj.MouseButton1Click:Connect(function()
						teleport(pos)
					end)
				end
			end
		end
	end
end

