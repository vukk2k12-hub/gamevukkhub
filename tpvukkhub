-- Utility: ensure unique config name (append suffix if exists)
local function makeUniqueName(name, all)
	if not name or name == "" then return nil end
	if not all or type(all) ~= "table" then return name end
	if not all[name] then return name end
	local i = 1
	local newName = name .. " (" .. tostring(i) .. ")"
	while all[newName] do
		i = i + 1
		newName = name .. " (" .. tostring(i) .. ")"
	end
	return newName
end

