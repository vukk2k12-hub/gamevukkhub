-- FILE read/write helpers (keep same configs.json index)
--====================================================

local function ReadData()
	if not isfile(File) then
		return {}
	end

	local ok,data = pcall(function()
		return HttpService:JSONDecode(readfile(File))
	end)

	if ok and type(data) == "table" then
		return data
	end

	return {}
end

local function SaveData(tbl)
	writefile(File,HttpService:JSONEncode(tbl))
end

--====================================================
-- GET TP SLOT from current List UI
--====================================================

local function GetTPSlots()

	local result = {}

	for _,row in pairs(List:GetChildren()) do
		if row:IsA("Frame") then

			local slot = {
				name = "",
				pos = nil
			}

			for _,obj in pairs(row:GetChildren()) do
				if obj:IsA("TextBox") then
					slot.name = obj.Text
					break
				end
			end

			if row:FindFirstChild("SavedPos") then
				local p = row.SavedPos.Value
				if p then
					slot.pos = {
						x = p.X,
						y = p.Y,
						z = p.Z
					}
				end
			end

			table.insert(result,slot)
		end
	end

	return result
end

--====================================================
-- LOAD TP SLOTS into the TP list UI
--====================================================

local function LoadTPSlots(data)

	for _,v in pairs(List:GetChildren()) do
		if v:IsA("Frame") then
			v:Destroy()
		end
	end

	for _,v in pairs(MiniScroll:GetChildren()) do
		if v:IsA("Frame") then
			v:Destroy()
		end
	end

	for _,slot in ipairs(data) do
		createSlot(slot)
	end
end

