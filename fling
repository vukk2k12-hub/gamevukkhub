Instance.new("UICorner", speedInput).CornerRadius = UDim.new(0, 6)

-- ==========================================
-- XỬ LÝ LOGIC HOẠT ĐỘNG
-- ==========================================

local isFlingEnabled = true
local flingSpeed = 850

toggleButton.MouseButton1Click:Connect(function()
	isFlingEnabled = not isFlingEnabled
	toggleButton.Text = isFlingEnabled and "Fling: ON" or "Fling: OFF"
	toggleButton.BackgroundColor3 = isFlingEnabled and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(120, 120, 120)
end)

-- Bỏ giới hạn, nhập thoải mái
speedInput:GetPropertyChangedSignal("Text"):Connect(function()
	local numericText = speedInput.Text:gsub("%D", "")
	if numericText ~= "" then
		flingSpeed = tonumber(numericText)
		speedInput.Text = numericText
	else
		flingSpeed = 0
	end
end)

closeButton.MouseButton1Click:Connect(function() screenGui:Destroy() end)

-- Kéo thả Menu
local isDragging, dragStartPos, frameStartPos
mainFrame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		isDragging = true
		dragStartPos = input.Position
		frameStartPos = mainFrame.Position
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if isDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStartPos
		mainFrame.Position = UDim2.new(frameStartPos.X.Scale, frameStartPos.X.Offset + delta.X, frameStartPos.Y.Scale, frameStartPos.Y.Offset + delta.Y)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then isDragging = false end
end)

-- Logic Fling
Workspace.ChildAdded:Connect(function(child)
	if child.Name == "GrabParts" then
		local grabPart = child:FindFirstChild("GrabPart")
		if not grabPart then return end
		local weldConstraint = grabPart:FindFirstChild("WeldConstraint")
		if weldConstraint and weldConstraint.Part1 then
			local targetPart = weldConstraint.Part1
			local bodyVelocity = Instance.new("BodyVelocity")
			bodyVelocity.Parent = targetPart
			child:GetPropertyChangedSignal("Parent"):Connect(function()
				if not child.Parent and isFlingEnabled then
					bodyVelocity.MaxForce = Vector3.new(1e9, 1e9, 1e9)
					bodyVelocity.Velocity = Workspace.CurrentCamera.CFrame.LookVector * flingSpeed
					Debris:AddItem(bodyVelocity, 0.5)
				end
			end)
		end
	end
end)
