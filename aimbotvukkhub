    local function updatePlayerList()
        for _,v in pairs(TargetFrame:GetChildren()) do
            if v:IsA("TextButton") and v~=ResetBtn then
                v:Destroy()
            end
        end

        local y=35
        for _,plr in pairs(Players:GetPlayers()) do
            if plr~=player then
                local btn=Instance.new("TextButton",TargetFrame)
                btn.Size=UDim2.new(1,0,0,25)
                btn.Position=UDim2.new(0,0,0,y)
                y=y+25
                btn.Text=plr.Name
                btn.BackgroundColor3=Color3.fromRGB(100,180,255)

                btn.MouseButton1Click:Connect(function()
                    priorityTarget=plr
                end)
            end
        end
    end

    Players.PlayerAdded:Connect(updatePlayerList)

    Players.PlayerRemoving:Connect(function(plr)
        if espLines[plr] then
            espLines[plr]:Remove()
            espLines[plr]=nil
        end
        updatePlayerList()
    end)

    updatePlayerList()

    local function canSee(targetHead)
        if not wallCheck then return true end
        local rayParams=RaycastParams.new()
        rayParams.FilterDescendantsInstances={player.Character}
        rayParams.FilterType=Enum.RaycastFilterType.Blacklist

        local ray=Workspace:Raycast(
            Camera.CFrame.Position,
            targetHead.Position-Camera.CFrame.Position,
            rayParams
        )

        if ray and ray.Instance and not ray.Instance:IsDescendantOf(targetHead.Parent) then
            return false
        end
        return true
    end

    local function withinAimRange(head)
        if not player.Character or not player.Character:FindFirstChild("Head") then
            return false
        end
        local pHead = player.Character.Head
        local d = (pHead.Position - head.Position).Magnitude
        if aimRange == 0 then
            return true
        end
        return d <= aimRange
    end

    local function getClosestTarget()

        local center=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)
        local fov=tonumber(FOVBox.Text) or 100

        -- refresh aimRange from DistanceBox (tab 3)
        aimRange = tonumber(DistanceBox.Text) or 0

        if priorityTarget and priorityTarget.Character then
            local head=priorityTarget.Character:FindFirstChild("Head")
            local hum=priorityTarget.Character:FindFirstChildOfClass("Humanoid")
            if head and hum and hum.Health>0 then
                local pos,onScreen=Camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local dist2d=(Vector2.new(pos.X,pos.Y)-center).Magnitude
                    if dist2d<=fov and canSee(head) and withinAimRange(head) then
                        return priorityTarget
                    end
                end
            end
        end

        local closest=nil
        local shortest=math.huge

        for _,plr in pairs(Players:GetPlayers()) do
            if plr~=player and plr.Character and plr.Character:FindFirstChild("Head") then

                local humanoid=plr.Character:FindFirstChildOfClass("Humanoid")

                if humanoid and humanoid.Health>0 then

                    if (not friendCheck or not player:IsFriendsWith(plr.UserId)) and
                       (not teamCheck or plr.Team~=player.Team) then

                        if teamNumCheck then
                            local a = plr:GetAttribute("TeamNum")
                            local b = player:GetAttribute("TeamNum")
                            if a and b and a == b then
                                continue
                            end
                        end

                        local head=plr.Character.Head
                        local screenPos,onScreen=Camera:WorldToViewportPoint(head.Position)

                        if onScreen then
                            local dist2d=(Vector2.new(screenPos.X,screenPos.Y)-center).Magnitude

                            if dist2d<=fov and dist2d<shortest and canSee(head) and withinAimRange(head) then
                                shortest=dist2d
                                closest=plr
                            end
                        end
                    end
                end
            end
        end

        if closest then
            return closest
        end

        if aimNPC then
            local closestNPC=nil
            local shortestNPC=math.huge

            for _,npc in pairs(Workspace:GetDescendants()) do
                if npc:IsA("Model") and npc:FindFirstChild("Humanoid") and npc:FindFirstChild("Head") then
                    if Players:GetPlayerFromCharacter(npc)==nil then

                        local hum=npc.Humanoid
                        if hum.Health>0 then

                            if teamNumCheck then
                                local npcNum = npc:GetAttribute("TeamNum")
                                local playerNum = player:GetAttribute("TeamNum")
                                if npcNum and playerNum and npcNum == playerNum then
                                    continue
                                end
                            end

                            local head=npc.Head
                            local screenPos,onScreen=Camera:WorldToViewportPoint(head.Position)

                            if onScreen then
                                local dist=(Vector2.new(screenPos.X,screenPos.Y)-center).Magnitude

                                if dist<=fov and dist<shortestNPC and canSee(head) and withinAimRange(head) then
                                    shortestNPC=dist
                                    closestNPC=npc
                                end
                            end
                        end
                    end
                end
            end

            return closestNPC
        end

        return nil
    end

    RunService.RenderStepped:Connect(function()

        FOVCircle.Position=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)
        FOVCircle.Radius=tonumber(FOVBox.Text) or 100

        if espOn then

            espDistance=tonumber(ESPDistBox.Text) or 100

            for _,plr in pairs(Players:GetPlayers()) do
                if plr~=player and plr.Character and plr.Character:FindFirstChild("Head") then

                    local humanoid=plr.Character:FindFirstChildOfClass("Humanoid")

                    if humanoid and humanoid.Health>0 then

                        if not espLines[plr] then
                            espLines[plr]=Drawing.new("Line")
                            espLines[plr].Thickness=2
                        end

                        local head=plr.Character.Head
                        local screenPos,onScreen=Camera:WorldToViewportPoint(head.Position)
                        local line=espLines[plr]

                        if player.Character and player.Character:FindFirstChild("Head") then
                            local dist=(player.Character.Head.Position-head.Position).Magnitude

                            if onScreen and dist<=espDistance then
                                line.Visible=true
                                line.From=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y)
                                line.To=Vector2.new(screenPos.X,screenPos.Y)

                                if player:IsFriendsWith(plr.UserId) then
                                    line.Color=Color3.fromRGB(0,255,0)
                                else
                                    -- Blue sky color instead of red
                                    line.Color=Color3.fromRGB(135,206,250)
                                end
                            else
                                line.Visible=false
                            end
                        end
                    end
                end
            end
        end

        if aimOn then
            local target=getClosestTarget()

            if target then

                local head=nil

                if target:IsA("Player") then
                    if target.Character then
                        head=target.Character:FindFirstChild("Head")
                    end
                else
                    head=target:FindFirstChild("Head")
                end

                if head then
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, head.Position)

                    -- Auto shot logic: try to Activate the tool with a small cooldown
                    if autoShot then
                        if tick() - lastAutoShot >= autoShotInterval then
                            lastAutoShot = tick()
                            pcall(function()
                                if player.Character then
                                    local tool = player.Character:FindFirstChildOfClass("Tool")
                                    if tool and tool.Parent then
                                        tool:Activate()
                                    end
                                end
                            end)
                        end
                    end
                end
            end
        end
    end)

