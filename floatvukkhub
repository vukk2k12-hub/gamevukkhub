-- Drag
local dragging, dragInput, dragStart, startPos

local function update(input)
    local delta = input.Position - dragStart
    frame.Position = UDim2.new(
        startPos.X.Scale,
        startPos.X.Offset + delta.X,
        startPos.Y.Scale,
        startPos.Y.Offset + delta.Y
    )
end

frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 
    or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

frame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement 
    or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end)

-- Float logic
local isFloating = false
local floatOffset = 3.5
local platform, keepUpdating

local function updateUI()
    toggleBtn.Text = "Float: " .. (isFloating and "ON" or "OFF") .. " (" .. floatOffset .. ")"
end

local function createPlatform()
    if platform and platform.Parent then return end
    platform = Instance.new("Part")
    platform.Size = Vector3.new(10,1,10)
    platform.Anchored = true
    platform.CanCollide = true
    platform.Transparency = 1
    platform.Parent = workspace
end

local function enableFloat()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    createPlatform()
    keepUpdating = true

    task.spawn(function()
        while keepUpdating do
            if not (platform and hrp and hrp.Parent) then break end
            platform.Position = hrp.Position - Vector3.new(0, floatOffset, 0)
            RunService.Heartbeat:Wait()
        end
    end)
end

local function disableFloat()
    keepUpdating = false
    if platform then
        platform:Destroy()
        platform = nil
    end
end

-- Toggle
toggleBtn.MouseButton1Click:Connect(function()
    isFloating = not isFloating
    if isFloating then
        enableFloat()
    else
        disableFloat()
    end
    updateUI()
end)

-- +/- control
minusBtn.MouseButton1Click:Connect(function()
    floatOffset = math.max(0.5, floatOffset - 0.5)
    updateUI()
end)

plusBtn.MouseButton1Click:Connect(function()
    floatOffset = math.min(20, floatOffset + 0.5)
    updateUI()
end)

-- Close
closeBtn.MouseButton1Click:Connect(function()
    screenGui:Destroy()
    disableFloat()
end)

-- Respawn handling
player.CharacterRemoving:Connect(function()
    disableFloat()
end)

player.CharacterAdded:Connect(function()
    if isFloating then
        task.wait(1)
        enableFloat()
    end
end)
