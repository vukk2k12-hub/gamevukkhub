-------------------------------------------------
-- DETECT /me
-------------------------------------------------
local function watchPlayer(plr)
	plr.Chatted:Connect(function(msg)
		if string.lower(msg):find("/me") then
			if not adminList[plr.Name] then
				adminList[plr.Name] = true
				saveAdmins()
				refreshPlayerList()
			end
		end
	end)
end

-------------------------------------------------
-- WATCH PLAYERS
-------------------------------------------------
for _,p in pairs(Players:GetPlayers()) do
	if p ~= LocalPlayer then
		watchPlayer(p)
	end
end

Players.PlayerAdded:Connect(function(p)
	watchPlayer(p)
	refreshPlayerList()
end)

Players.PlayerRemoving:Connect(function()
	refreshPlayerList()
end)

