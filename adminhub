-------------------------------------------------
-- CREATE COMMAND BUTTON
-------------------------------------------------
local function createCommandBtn(cmdName, cmdValue)
	local btn = Instance.new("TextButton")
	btn.Parent = commandScroll
	btn.Size = UDim2.new(1,-8,0,35)
	btn.BackgroundColor3 = Color3.fromRGB(255,80,80)
	btn.Text = cmdName
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 12
	btn.TextColor3 = Color3.new(1,1,1)
	btn.Name = cmdValue
	Instance.new("UICorner",btn)
	btn.MouseButton1Click:Connect(function()
		if selectedCommand then
			selectedCommand.BackgroundColor3 = Color3.fromRGB(255,80,80)
		end
		selectedCommand = btn
		btn.BackgroundColor3 = Color3.fromRGB(80,200,80)
	end)
	return btn
end

-------------------------------------------------
-- CREATE PLAYER BUTTON
-------------------------------------------------
local function createPlayerBtn(playerName)
	local isOnline = Players:FindFirstChild(playerName) ~= nil
	local btn = Instance.new("TextButton")
	btn.Parent = playerScroll
	btn.Size = UDim2.new(1,-8,0,35)
	btn.BackgroundColor3 = Color3.fromRGB(255,80,80)
	btn.Text = playerName
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 12
	btn.BorderSizePixel = 2
	btn.BorderColor3 = Color3.fromRGB(0,0,0)
	btn.Name = playerName
	if isOnline then
		btn.TextColor3 = Color3.fromRGB(0,180,0)
	else
		btn.TextColor3 = Color3.fromRGB(220,0,0)
	end
	Instance.new("UICorner",btn)
	btn.MouseButton1Click:Connect(function()
		if selectedPlayers[playerName] then
			selectedPlayers[playerName] = nil
			btn.BackgroundColor3 = Color3.fromRGB(255,80,80)
		else
			selectedPlayers[playerName] = true
			btn.BackgroundColor3 = Color3.fromRGB(80,200,80)
		end
	end)
	return btn
end

-------------------------------------------------
-- REFRESH COMMAND LIST
-------------------------------------------------
local function refreshCommandList()
	for _,v in pairs(commandScroll:GetChildren()) do
		if v:IsA("TextButton") then
			v:Destroy()
		end
	end
	for _,cmd in pairs(commands) do
		createCommandBtn(cmd.name, cmd.cmd)
	end
	commandLayout:ApplyLayout()
	commandScroll.CanvasSize = UDim2.new(0,0,0,commandLayout.AbsoluteContentSize.Y)
end

-------------------------------------------------
-- REFRESH PLAYER LIST
-------------------------------------------------
local function refreshPlayerList()
	for _,v in pairs(playerScroll:GetChildren()) do
		if v:IsA("TextButton") then
			v:Destroy()
		end
	end
	local playerList = {}
	for name,_ in pairs(adminList) do
		table.insert(playerList, name)
	end
	table.sort(playerList)
	for _,name in pairs(playerList) do
		createPlayerBtn(name)
	end
	playerLayout:ApplyLayout()
	playerScroll.CanvasSize = UDim2.new(0,0,0,playerLayout.AbsoluteContentSize.Y)
end

