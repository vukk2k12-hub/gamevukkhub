dragIcon.Size = UDim2.new(0,28,0,28)
dragIcon.Position = UDim2.new(0,40,0,6)
dragIcon.BackgroundTransparency = 1
dragIcon.Image = "rbxassetid://16743659815"
dragIcon.Name = "DragIcon"

do
    local dragging = false
    local dragInput, mousePos, mainPos
    dragIcon.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            mousePos = input.Position
            mainPos = main.Position
            local conn
            conn = UIS.InputChanged:Connect(function(input2)
                if input2.UserInputType == Enum.UserInputType.MouseMovement or input2.UserInputType == Enum.UserInputType.Touch then
                    if dragging then
                        local delta = input2.Position - mousePos
                        main.Position = UDim2.new(
                            mainPos.X.Scale, mainPos.X.Offset + delta.X,
                            mainPos.Y.Scale, mainPos.Y.Offset + delta.Y
                        )
                    end
                end
            end)
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    conn:Disconnect()
                end
            end)
        end
    end)
end

